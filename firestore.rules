rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == "venomzaak@gmail.com";
    }

    function isOwner() {
      return signedIn()
        && (
          resource.data.ownerId == request.auth.uid
          || resource.data.createdBy == request.auth.uid
        );
    }

    function isApproved() {
      return resource.data.status == "approved";
    }

    function downloadIncrementOnly() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(["downloads", "updatedAt"])
        && request.resource.data.downloads == resource.data.downloads + 1;
    }

    function ratingAggregateOnly() {
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["ratingTotal", "ratingCount", "updatedAt"])
        && request.resource.data.ratingTotal >= 0
        && request.resource.data.ratingCount >= resource.data.ratingCount;
    }

    function ownerContentUpdateOnly() {
      return isOwner()
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "title",
          "description",
          "category",
          "version",
          "size",
          "fileUrl",
          "coverUrl",
          "screenshots",
          "status",
          "featured",
          "updatedAt"
        ])
        && request.resource.data.status == "pending"
        && request.resource.data.featured == false;
    }

    match /games/{gameId} {
      allow read: if isApproved() || isAdmin() || isOwner();

      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.featured == false;

      allow update: if isAdmin() || downloadIncrementOnly() || ratingAggregateOnly() || ownerContentUpdateOnly();
      allow delete: if isAdmin() || isOwner();

      match /ratings/{userId} {
        allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
        allow create, update: if signedIn()
          && request.auth.uid == userId
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5;
        allow delete: if isAdmin();
      }
    }

    match /users/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}
